<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView

    xmlns:app="http://schemas.android.com"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"

    app:cardElevation="3dp"
    layout_height="">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- أيقونة تمثل الفئة (Category) -->
        <View
            android:id="@+id/viewCategoryColor"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:background="#DDDDDD" /> <!-- خط جانبي ملون -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- عنوان المعاملة (مثلاً: شراء هاتف) -->
            <TextView
                android:id="@+id/tvTransactionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عنوان المعاملة"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- الفئة والتاريخ -->
            <TextView
                android:id="@+id/tvTransactionDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="التصنيف • 12/10/2023"
                android:textColor="#757575"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- المبلغ (Amount) -->
        <TextView
            android:id="@+id/tvTransactionAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
